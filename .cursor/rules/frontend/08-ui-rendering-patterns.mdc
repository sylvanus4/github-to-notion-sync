## 4. InfoBox (읽기 전용 정보 표시)

```tsx
import { InfoBox } from '@/shared/ui/field';

<InfoBox label={t('section.labels.volume')} value={volumeName} />
<InfoBox label={t('section.labels.path')} value={path} trailing={<CopyButton text={path} />} />
<InfoBox label={t('section.labels.info')}>
  <div className="flex gap-2">
    <Badge theme="blu">{item.type}</Badge>
    <span>{item.name}</span>
  </div>
</InfoBox>
```

