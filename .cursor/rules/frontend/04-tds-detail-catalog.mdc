## Badge / Tag / StatusIndicator

```tsx
interface BadgeProps {
  theme?: 'blu' | 'red' | 'gry' | 'gre' | 'ylw';
  size?: 'sm' | 'md' | 'lg';
  type?: 'subtle' | 'solid';
  layout?: 'text-only' | 'left-icon' | 'right-icon';
  icon?: ReactElement;
}

interface StatusIndicatorProps {
  variant?:
    | 'active'
    | 'error'
    | 'suspended'
    | 'shelved'
    | 'shutoff'
    | 'down'
    | 'paused'
    | 'building'
    | 'inUse'
    | 'degraded'
    | 'offline'
    | 'noMonitor'
    | 'pending'
    | 'draft'
    | 'mounted'
    | 'deleting';
  colorScheme?: 'success' | 'danger' | 'warning' | 'muted' | 'info';
  label?: string;
  layout?: 'leftIcon' | 'iconOnly';
  tooltip?: string;
  customIcon?: ReactNode;
}
```

상태 매핑 함수:

```tsx
const mapStatusToVariant = (status: string): StatusVariant => {
  switch (status.toLowerCase()) {
    case 'active':
    case 'running':
    case 'succeeded':
      return 'active';
    case 'pending':
      return 'pending';
    case 'creating':
    case 'building':
      return 'building';
    case 'deleting':
    case 'terminating':
      return 'deleting';
    case 'stopped':
    case 'suspended':
      return 'suspended';
    case 'failed':
    case 'error':
      return 'error';
    default:
      return 'paused';
  }
};
```

