## TcTable (렌더 프롭 기반)

suite에서 주력 테이블. Table/SelectableTable 대안.

```tsx
interface TcTableBodyProps<T> {
  type?: 'none' | 'radio' | 'checkbox';
  isLoading: boolean;
  rowData?: T[] | null;
  columnNames: string[];
  onSortChange?: OnSortChange;
  getSelectValue?: (row: T) => string | number;
  onChange?: (selectedValues: (string | number)[]) => void;
  expandableUI?: (row: T) => ReactElement;
  emptyUI?: ReactElement;
  selectOnRowClick?: boolean;
  expandOnRowClick?: boolean;
  getDisabled?: (row: T) => boolean;
  resizable?: boolean;
  children: (row: T, helpers: { selectCell: () => ReactNode; expandButton: () => ReactNode }) => ReactElement;
}
```

```tsx
<TcTable.Body
  isLoading={isLoading}
  rowData={rows}
  columnNames={['Name', 'Status', 'Created', '']}
  type="checkbox"
  getSelectValue={(r) => r.id}
  onChange={setSelectedIds}
  emptyUI={<EmptyUI content={{ title: t('empty.title') }} />}
>
  {(row, { selectCell }) => (
    <TcTable.Tr key={row.id}>
      <TcTable.Td>{selectCell()}</TcTable.Td>
      <TcTable.Td sortable>{row.name}</TcTable.Td>
      <TcTable.Td>{row.status}</TcTable.Td>
      <TcTable.Td iconColumn>
        <ContextMenu.Root
          trigger={({ toggle }) => (
            <Button variant="muted" appearance="ghost" size="sm" onClick={toggle}>
              <ActionIcon size="sm" />
            </Button>
          )}
        >
          <ContextMenu.Item action={() => onEdit(row)}>{t('common.edit')}</ContextMenu.Item>
          <ContextMenu.Item action={() => onDelete(row)} danger>
            {t('common.delete')}
          </ContextMenu.Item>
        </ContextMenu.Root>
      </TcTable.Td>
    </TcTable.Tr>
  )}
</TcTable.Body>
```

