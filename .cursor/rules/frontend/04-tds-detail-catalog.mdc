## Table / SelectableTable / ExpandableTable

### TableColumn

```tsx
interface TableColumn {
  key: string;
  header?: string;
  width?: number | string;
  align?: 'left' | 'center' | 'right';
  sortable?: boolean;
  clickable?: boolean;
  isEllipsis?: boolean;
}
```

### Table

```tsx
interface TableProps<TData> {
  rows: TData[];
  columns: TableColumn[];
  isLoading?: boolean;
  emptyUI?: React.ReactNode;
  sort?: string;
  order?: 'asc' | 'desc';
  onSortChange?: (sort: string | null, order: 'asc' | 'desc') => void;
  stickyLastColumn?: boolean;
  children?: React.ReactNode;
}
```

**Table.Tr:** `rowData`, `onClick?`, `isError?`, `disabled?`
**Table.Td:** `rowData`, `column`, `preventClickPropagation?`, `colSpan?`

### SelectableTable

```tsx
interface SelectableTableProps<TData> extends Omit<TableProps<TData>, 'children'> {
  selectionType: 'checkbox' | 'radio';
  selectedRows?: (string | number)[];
  onRowSelectionChange?: (ids: (string | number)[]) => void;
  getRowId: (row: TData, index: number) => string | number;
  selectOnRowClick?: boolean;
  isRowDisabled?: (row: TData, index: number) => boolean;
  children: React.ReactNode;
}
```

### ExpandableTable

```tsx
interface ExpandableTableProps<TData> extends Omit<TableProps<TData>, 'children'> {
  expandedRowRender: (row: TData) => React.ReactNode;
  expandRowByClick?: boolean;
  selectionType?: 'checkbox' | 'radio';
  selectedRows?: (string | number)[];
  onRowSelectionChange?: (ids: (string | number)[]) => void;
  getRowId?: (row: TData, index: number) => string | number;
}
```

**패턴:**

```tsx
<SelectableTable
  columns={columns}
  rows={tableRows}
  selectionType="checkbox"
  selectedRows={selectedRows}
  onRowSelectionChange={setSelectedRows}
  getRowId={(row) => row.id}
  isLoading={isLoading}
  sort={sort}
  order={order}
  onSortChange={handleSortChange}
  stickyLastColumn
  selectOnRowClick={false}
  emptyUI={<EmptyUI content={{ title: t('empty.title') }} />}
>
  {tableRows.map((row) => (
    <Table.Tr key={row.id} rowData={row} onClick={() => navigate(`/detail/${row.id}`)}>
      {columns.map((col) => (
        <Table.Td key={col.key} rowData={row} column={col} preventClickPropagation={col.key === 'action'}>
          {cellRenderers[col.key]?.(row) ?? row[col.key] ?? '-'}
        </Table.Td>
      ))}
    </Table.Tr>
  ))}
</SelectableTable>
```

