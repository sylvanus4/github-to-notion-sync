## Overlay / useOverlay

```tsx
interface OverlayOptions {
  type?: 'modal' | 'drawer-horizontal' | 'drawer-vertical';
  size?: 'sm' | 'md';
  title?: React.ReactNode;
  description?: React.ReactNode;
  footer?: React.ReactElement;
  confirmUI?: React.ReactNode;
  cancelUI?: React.ReactNode;
  rejectOnCancel?: boolean;
}
```

**openOverlay:**

```tsx
const { openOverlay } = useOverlay();
const result = await openOverlay({
  component: MyDrawer,
  props: { itemName: 'test' },
  options: { type: 'drawer-horizontal', size: 'md' },
});
```

**Overlay 컴포넌트 정의 (CRITICAL):**

```tsx
interface MyDrawerProps extends Omit<OverlayProps, 'onConfirm'> {
  itemName: string;
  onConfirm?: (result: SomeResult) => void;
}

const MyDrawer = ({ itemName, onConfirm, onCancel, ...restProps }: MyDrawerProps) => (
  <Overlay.Template
    {...restProps}
    title="My Drawer"
    onConfirm={() => onConfirm?.({ success: true })}
    onCancel={onCancel}
  >
    {/* content */}
  </Overlay.Template>
);
```

