## ActionModal / ResourceActionModal / DeleteResourceModal

```tsx
interface ActionConfig {
  title: string;
  subtitle?: string;
  actionButtonText: string;
  actionButtonVariant: 'error' | 'primary' | 'secondary';
  cancelButtonText?: string;
}

interface ResourceActionModalProps extends ActionModalProps {
  content?: {
    type?: 'success' | 'info' | 'warning' | 'error';
    message: string;
  };
  infoItems?: InfoItem[];
  showSeparator?: boolean;
  loadingText?: string;
}

interface InfoItem {
  label: string;
  values: string[];
  variant?: 'gray' | 'blue';
  showBullets?: boolean;
}

interface DeleteResourceModalProps extends Omit<OverlayProps, 'children'> {
  targets: DeleteResourceTarget[];
  forceBulk?: boolean;
  infoItems?: InfoItem[];
  content?: { type: 'error' | 'warning'; message: string } | null;
  labels?: DeleteResourceModalLabels;
  onAction?: () => void | Promise<void>;
}
```

**삭제 확인 3단계:**

```tsx
// 1. 단순 확인
await openOverlay({ component: ActionModal, props: { actionConfig: { title, actionButtonText, actionButtonVariant: 'error' } } });

// 2. 리소스 상세
await openOverlay({ component: ResourceActionModal, props: { actionConfig: {…}, infoItems: [{label, values, variant: 'gray'}], content: {type: 'warning', message} } });

// 3. 표준 삭제 (단일/벌크 자동 분기)
await openOverlay({ component: DeleteResourceModal, props: { targets: items.map(i => ({id: i.id, name: i.name})), labels: {titleSingle, titleBulk} } });
```

