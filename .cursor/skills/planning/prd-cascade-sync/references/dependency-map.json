{
  "$schema": "PRD Cascade Sync Dependency Map",
  "version": "1.0.0",
  "description": "프로젝트별 PRD 파이프라인 노드 간 의존 관계를 정의합니다. 이 파일을 프로젝트에 맞게 수정하세요.",
  "node_types": [
    "requirement",
    "user-story",
    "acceptance-criteria",
    "ui-spec",
    "design-spec",
    "api-spec",
    "qa-scenario",
    "policy"
  ],
  "relation_types": [
    {
      "name": "derives-from",
      "description": "하류 노드가 상류 노드로부터 파생됨",
      "propagation": "downstream"
    },
    {
      "name": "constrains",
      "description": "상류 노드가 하류 노드의 범위를 제한함",
      "propagation": "downstream"
    },
    {
      "name": "implements",
      "description": "하류 노드가 상류 노드를 구현함",
      "propagation": "downstream"
    },
    {
      "name": "verifies",
      "description": "하류 노드가 상류 노드를 검증함",
      "propagation": "downstream"
    }
  ],
  "default_edges": [
    { "from": "requirement", "to": "user-story", "relation": "derives-from" },
    { "from": "user-story", "to": "acceptance-criteria", "relation": "derives-from" },
    { "from": "acceptance-criteria", "to": "ui-spec", "relation": "implements" },
    { "from": "acceptance-criteria", "to": "api-spec", "relation": "implements" },
    { "from": "ui-spec", "to": "design-spec", "relation": "implements" },
    { "from": "ui-spec", "to": "qa-scenario", "relation": "verifies" },
    { "from": "api-spec", "to": "qa-scenario", "relation": "verifies" },
    { "from": "policy", "to": "requirement", "relation": "constrains" },
    { "from": "policy", "to": "ui-spec", "relation": "constrains" }
  ],
  "projects": {
    "_template": {
      "nodes": [
        {
          "id": "REQ-001",
          "type": "requirement",
          "title": "예시 요구사항",
          "notion_page_id": "notion-page-id-here",
          "notion_url": "https://notion.so/..."
        }
      ],
      "edges": [
        {
          "from": "REQ-001",
          "to": "US-001",
          "relation": "derives-from"
            }
          ]
        },
        "ai-model-event-stock-analytics": {
          "description": "Stock analytics pipeline — file-based PRDs in docs/ and specs/, no Notion PRD integration",
          "change_detection": "method-c-git-diff",
          "nodes": [
            {
              "id": "FR-1",
              "type": "requirement",
              "title": "일일 주식 데이터 동기화",
              "source_file": "docs/specs/daily-stock-sync.md"
            },
            {
              "id": "FR-2",
              "type": "requirement",
              "title": "멀티팩터 종목 스크리닝",
              "source_file": "docs/specs/stock-screening.md"
            },
            {
              "id": "FR-3",
              "type": "requirement",
              "title": "기술적 분석 (Turtle/Bollinger/Oscillator)",
              "source_file": "docs/specs/technical-analysis.md"
            },
            {
              "id": "FR-4",
              "type": "requirement",
              "title": "일일 한국어 리포트 생성",
              "source_file": "docs/specs/daily-report.md"
            },
            {
              "id": "FR-5",
              "type": "requirement",
              "title": "Slack 배포 및 알림",
              "source_file": "docs/specs/slack-distribution.md"
            },
            {
              "id": "POL-1",
              "type": "policy",
              "title": "KIS 거래 안전 규칙",
              "source_file": ".cursor/rules/kis-safety.mdc"
            }
          ],
          "edges": [
            { "from": "FR-1", "to": "FR-2", "relation": "derives-from", "note": "동기화된 데이터가 스크리닝 입력" },
            { "from": "FR-2", "to": "FR-3", "relation": "derives-from", "note": "스크리닝 통과 종목에 TA 적용" },
            { "from": "FR-3", "to": "FR-4", "relation": "derives-from", "note": "TA 결과가 리포트에 포함" },
            { "from": "FR-4", "to": "FR-5", "relation": "implements", "note": "리포트를 Slack으로 배포" },
            { "from": "POL-1", "to": "FR-1", "relation": "constrains", "note": "KIS 안전 규칙이 데이터 소스 제한" },
            { "from": "POL-1", "to": "FR-5", "relation": "constrains", "note": "주문 실행 전 확인 의무" }
          ]
        }
      }
    }
